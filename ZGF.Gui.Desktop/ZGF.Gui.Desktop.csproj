<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
      <InternalsVisibleTo Include="ZGF.Gui.Sandbox" />
    </ItemGroup>

    <!-- In-process MCP server (GuiMcpServer) for driving the live window from an LLM/agent.
         The Streamable HTTP transport is self-hosted over System.Net.HttpListener — no ASP.NET. -->
    <ItemGroup>
      <PackageReference Include="McpSdk.Server" />
      <PackageReference Include="McpSdk.Adapter.System.Text.Json" />
      <PackageReference Include="McpSdk.Adapter.StreamableHttpServer" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\ZGF.Gui\ZGF.Gui.csproj" />
      <ProjectReference Include="..\ZGF.Gui.Metal\ZGF.Gui.Metal.csproj" />
      <ProjectReference Include="..\ZGF.Gui.OpenGL\ZGF.Gui.OpenGL.csproj" />
      <ProjectReference Include="..\ZGF.Desktop\ZGF.Desktop.csproj" />
      <ProjectReference Include="..\ZGF.Rendering.Metal\ZGF.Rendering.Metal.csproj" />
      <ProjectReference Include="..\OpenGL.NET\OpenGL.NET.csproj" />
      <ProjectReference Include="..\OpenGL.NET.Abstractions\OpenGL.NET.Abstractions.csproj" />
      <ProjectReference Include="..\PngSharp\PngSharp\PngSharp.csproj" />
      <ProjectReference Include="..\ZGF.AppUtils\ZGF.AppUtils.csproj" />
      <ProjectReference Include="..\ZGF.Fonts\ZGF.Fonts.csproj" />
      <ProjectReference Include="..\ZGF.Geometry\ZGF.Geometry.csproj" />
      <ProjectReference Include="..\ZGF.KeyboardModule\ZGF.KeyboardModule.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Backends\" />
      <Folder Include="Components\" />
      <Folder Include="Platforms\" />
    </ItemGroup>

</Project>
