<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- iOS compile coverage is opt-in: `dotnet build -p:BuildIos=true` (needs the ios workload). -->
        <TargetFrameworks>net10.0$(IosTfmSuffix)</TargetFrameworks>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <!-- Platform-neutral Metal + Objective-C interop. No GLFW / OpenGL / GUI deps, so the
         same Metal rendering host contract is reusable from both the desktop (NSWindow)
         and a future iOS (UIView/CAMetalLayer) windowing layer. -->

</Project>
