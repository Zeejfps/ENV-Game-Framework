<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\SlangIntegrationTest\SlangIntegrationTest.csproj" />
    </ItemGroup>

    <Target Name="CopySlangNativesForTool" BeforeTargets="Build">
        <ItemGroup>
            <_SlangNative Include="..\..\SlangIntegrationTest\Native\win-x64\*.dll"     Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
            <_SlangNative Include="..\..\SlangIntegrationTest\Native\win-arm64\*.dll"   Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
            <_SlangNative Include="..\..\SlangIntegrationTest\Native\osx-x64\*.dylib"   Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
            <_SlangNative Include="..\..\SlangIntegrationTest\Native\osx-arm64\*.dylib" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
            <_SlangNative Include="..\..\SlangIntegrationTest\Native\linux-x64\*.so"    Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
        </ItemGroup>
        <Copy SourceFiles="@(_SlangNative)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" Retries="2" />
    </Target>

</Project>
