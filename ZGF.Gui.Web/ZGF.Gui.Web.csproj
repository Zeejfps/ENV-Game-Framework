<Project Sdk="Microsoft.NET.Sdk">

    <!--
      Browser (WASM) host for ZGF GUI: .NET WASM browser-app model (JSExport/
      JSImport), not Blazor; renders a <canvas> + WebGL2. Runs FreeType raster +
      HarfBuzz shaping as statically-linked wasm native libs.

      Build/run (needs wasm-tools workload; build native/wasm/libfreetype.a first):
          dotnet workload install wasm-tools
          tools/build-freetype-wasm.sh
          dotnet build -c Release ZGF.Gui.Web/ZGF.Gui.Web.csproj
          # serve the AppBundle statically, e.g.:
          (cd bin/Release/net10.0-browser/browser-wasm/AppBundle && python3 -m http.server 8080)
      `dotnet run` does not work here (no perHostConfig under plain Microsoft.NET.Sdk).

      Listed in "ENV Game Framework.sln" (so IDEs load it) but excluded from the
      solution Build.0 mappings, so a normal solution build needs no wasm toolchain.
    -->

    <PropertyGroup>
        <TargetFramework>net10.0-browser</TargetFramework>
        <!-- Set here (not via -r) so the RID doesn't propagate to the net9/net6 refs. -->
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
        <OutputType>Exe</OutputType>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <WasmMainJSPath>main.js</WasmMainJSPath>

        <!-- Native deps on wasm require an AOT/native relink. -->
        <RunAOTCompilation>true</RunAOTCompilation>
        <WasmBuildNative>true</WasmBuildNative>

        <!-- Make the referenced toolkit projects expose their net10.0-browser target
             (the global property propagates across the project references). -->
        <BuildWasm>true</BuildWasm>
    </PropertyGroup>

    <ItemGroup>
        <!-- Page + JS shims into the AppBundle (main.js ships via WasmMainJSPath). -->
        <WasmExtraFilesToDeploy Include="index.html" />
        <WasmExtraFilesToDeploy Include="files.js" />
        <WasmExtraFilesToDeploy Include="webgl2.js" />
        <WasmExtraFilesToDeploy Include="clipboard.js" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\ZGF.Fonts\ZGF.Fonts.csproj" />
        <ProjectReference Include="..\ZGF.Gui\ZGF.Gui.csproj" />
    </ItemGroup>

    <ItemGroup>
        <!-- Reuse the desktop canvas shaders as the single source of truth; GlslEs.Adapt
             rewrites the #version 410 header to GLSL ES 3.00 at load (see Rendering/GlslEs.cs). -->
        <EmbeddedResource Include="..\ZGF.Gui.Desktop\Assets\Shaders\*.glsl">
            <LogicalName>%(Filename)%(Extension)</LogicalName>
        </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
        <!-- Shaping: published native asset (no custom build). The managed HarfBuzzSharp
             wrapper is pulled in transitively by ZGF.Fonts. -->
        <PackageReference Include="HarfBuzzSharp.NativeAssets.WebAssembly" Version="8.3.1.3" />
    </ItemGroup>

    <!-- The HarfBuzz package auto-links its .a only under the WebAssembly SDK; on
         plain Microsoft.NET.Sdk we link it ourselves (variant by threads/SIMD). -->
    <PropertyGroup>
        <_HbVariant Condition="'$(WasmEnableThreads)' == 'true'">mt</_HbVariant>
        <_HbVariant Condition="'$(WasmEnableThreads)' != 'true'">st</_HbVariant>
        <_HbVariant Condition="'$(WasmEnableSIMD)' == 'true'">$(_HbVariant),simd</_HbVariant>
    </PropertyGroup>
    <ItemGroup>
        <NativeFileReference Include="$(HarfBuzzSharpStaticLibraryPath)\3.1.56\$(_HbVariant)\libHarfBuzzSharp.a" />
    </ItemGroup>

    <ItemGroup>
        <!-- Rasterization: our self-built archive (tools/build-freetype-wasm.sh). -->
        <NativeFileReference Include="..\native\wasm\libfreetype.a" />
    </ItemGroup>

    <!-- FreeTypeSharp uses [DllImport("freetype")] but the lib is libfreetype.a;
         register "freetype" as a pinvoke module so resolution can fall through to
         the static table (paired with WasmFreeTypeResolver). -->
    <Target Name="_AddFreeTypePInvokeModule" BeforeTargets="_GenerateManagedToNative">
        <ItemGroup>
            <_WasmPInvokeModules Include="freetype" />
        </ItemGroup>
    </Target>

</Project>
