<Project Sdk="Microsoft.NET.Sdk">

    <!--
      Browser (WASM) host for ZGF GUI. This is the project that carries the
      browser-wasm NATIVE wiring described in docs/web-font-rendering.md:
        - our self-built libfreetype.a (NativeFileReference),
        - the published HarfBuzz wasm shaping asset, and
        - AOT + native relinking (required for native deps on wasm).

      It uses the lightweight ".NET WASM browser app" model (System.Runtime.
      InteropServices.JavaScript / [JSExport]/[JSImport]) rather than Blazor,
      because the eventual renderer drives a <canvas> + WebGL2 directly and the
      Blazor component layer would add nothing.

      STATUS: skeleton. Its only runnable behavior today is the font validation
      spike (FontSpike.Run, see docs §7). The WebGL2 canvas backend and the
      BeginFrame/EndFrame render loop are a separate plan; Tick() is the seam
      where they will plug in.

      Build/run (needs the wasm-tools workload AND a prior run of
      tools/build-freetype-wasm.sh to produce native/wasm/libfreetype.a):

          dotnet workload install wasm-tools
          tools/build-freetype-wasm.sh
          dotnet run -c Release (run from the ZGF.Gui.Web directory)

      This project IS listed in "ENV Game Framework.sln" (so IDEs load it), but
      it is deliberately excluded from the solution's Build.0 mappings so a
      normal solution-wide `dotnet build` does NOT require the wasm toolchain or
      the native archive. Build it explicitly when you want the web host.
    -->

    <PropertyGroup>
        <TargetFramework>net10.0-browser</TargetFramework>
        <!-- The browser-wasm RID is what triggers the WASM app-bundle build and
             makes `dotnet run` start the browser dev server. Set here (not via
             command-line -r) so it does NOT propagate to the net9.0/net6.0
             project references, which would demand wasm-tools-net9/net6. -->
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
        <OutputType>Exe</OutputType>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <WasmMainJSPath>main.js</WasmMainJSPath>

        <!-- Native deps on wasm require an AOT/native relink. -->
        <RunAOTCompilation>true</RunAOTCompilation>
        <WasmBuildNative>true</WasmBuildNative>

        <!-- Make the referenced toolkit projects expose their net10.0-browser target
             (the global property propagates across the project references). -->
        <BuildWasm>true</BuildWasm>
    </PropertyGroup>

    <ItemGroup>
        <!-- Static page + JS shims must land in the AppBundle. main.js is deployed
             via WasmMainJSPath; index.html and the [JSImport] modules loaded at
             runtime (files/webgl2/clipboard.js via JSHost.ImportAsync) are not, so
             deploy them explicitly. -->
        <WasmExtraFilesToDeploy Include="index.html" />
        <WasmExtraFilesToDeploy Include="files.js" />
        <WasmExtraFilesToDeploy Include="webgl2.js" />
        <WasmExtraFilesToDeploy Include="clipboard.js" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\ZGF.Fonts\ZGF.Fonts.csproj" />
        <ProjectReference Include="..\ZGF.Gui\ZGF.Gui.csproj" />
    </ItemGroup>

    <ItemGroup>
        <!-- Reuse the desktop canvas shaders as the single source of truth; GlslEs.Adapt
             rewrites the #version 410 header to GLSL ES 3.00 at load (see Rendering/GlslEs.cs). -->
        <EmbeddedResource Include="..\ZGF.Gui.Desktop\Assets\Shaders\*.glsl">
            <LogicalName>%(Filename)%(Extension)</LogicalName>
        </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
        <!-- Shaping: published native asset (no custom build). The managed HarfBuzzSharp
             wrapper is pulled in transitively by ZGF.Fonts. -->
        <PackageReference Include="HarfBuzzSharp.NativeAssets.WebAssembly" Version="8.3.1.3" />
    </ItemGroup>

    <!--
      The HarfBuzz package only auto-registers its native .a when the project uses
      the WebAssembly SDK (UsingMicrosoftNETSdkWebAssembly). This project uses the
      plain Microsoft.NET.Sdk, so we link it ourselves, mirroring the package's own
      variant selection (net9.0+ => 3.1.56; mt/st by threads; ",simd" by SIMD).
      The archive filename (libHarfBuzzSharp) already matches HarfBuzzSharp's
      [DllImport("libHarfBuzzSharp")], so it binds statically with no extra module. -->
    <PropertyGroup>
        <_HbVariant Condition="'$(WasmEnableThreads)' == 'true'">mt</_HbVariant>
        <_HbVariant Condition="'$(WasmEnableThreads)' != 'true'">st</_HbVariant>
        <_HbVariant Condition="'$(WasmEnableSIMD)' == 'true'">$(_HbVariant),simd</_HbVariant>
    </PropertyGroup>
    <ItemGroup>
        <NativeFileReference Include="$(HarfBuzzSharpStaticLibraryPath)\3.1.56\$(_HbVariant)\libHarfBuzzSharp.a" />
    </ItemGroup>

    <ItemGroup>
        <!-- Rasterization: our self-built archive (tools/build-freetype-wasm.sh). The HarfBuzz
             wasm package self-registers its own static lib via its build props; we only add
             FreeType. If the HarfBuzz package's props ever stop auto-registering, also add:
             <NativeFileReference Include="$(HarfBuzzSharpStaticLibraryPath)" /> -->
        <NativeFileReference Include="..\native\wasm\libfreetype.a" />
    </ItemGroup>

    <!--
      The wasm pinvoke-table generator derives a module name from each native
      file's FILENAME (libfreetype) and only statically binds [DllImport]s whose
      library name matches a module. FreeTypeSharp uses [DllImport("freetype")],
      which would NOT match "libfreetype" — so its calls would fall through to a
      runtime DllImportResolver (which FreeTypeSharp registers, and which throws
      PlatformNotSupportedException on browser). Registering "freetype" as a
      pinvoke module makes those calls bind directly to the statically-linked
      symbols in libfreetype.a, bypassing the resolver entirely.
    -->
    <Target Name="_AddFreeTypePInvokeModule" BeforeTargets="_GenerateManagedToNative">
        <ItemGroup>
            <_WasmPInvokeModules Include="freetype" />
        </ItemGroup>
    </Target>

</Project>
