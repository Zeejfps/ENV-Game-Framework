<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
      <!-- Fonts are embedded (see below); everything else under Assets is still copied next
           to the binary. Font license/readme files stay in the repo but are intentionally
           neither copied nor embedded. Backend shaders live in ZGF.Gui.Desktop. -->
      <Content Include="Assets\**\*" Exclude="Assets\Fonts\**\*">
        <Link>Assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <!-- Fonts are platform-independent, so they live in the core toolkit and are always
         embedded (no per-RID split), available to every platform package. -->
    <ItemGroup>
      <EmbeddedResource Include="Assets\Fonts\**\*.ttf">
        <LogicalName>%(Filename)%(Extension)</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

    <!-- Platform packages (e.g. ZGF.Gui.Desktop) load embedded fonts via internal helpers. -->
    <ItemGroup>
      <InternalsVisibleTo Include="ZGF.Gui.Desktop" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\PngSharp\PngSharp\PngSharp.csproj" />
      <ProjectReference Include="..\ZGF.AppUtils\ZGF.AppUtils.csproj" />
      <ProjectReference Include="..\ZGF.Fonts\ZGF.Fonts.csproj" />
      <ProjectReference Include="..\ZGF.Geometry\ZGF.Geometry.csproj" />
      <ProjectReference Include="..\ZGF.KeyboardModule\ZGF.KeyboardModule.csproj" />
    </ItemGroup>

</Project>
